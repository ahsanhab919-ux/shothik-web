# shothik-web environment variables
#
# Rules:
# - Anything prefixed with NEXT_PUBLIC_ is exposed to the browser.
# - Do not put secrets in NEXT_PUBLIC_ variables.
# - Do not commit .env.local or any real secret values.
#
# Setup:
#   cp .env.example .env.local
#   edit .env.local

################################################################################
# Public (Browser) – safe to expose
################################################################################

# App and external API routing
NEXT_PUBLIC_APP_URL=https://shothik.work
NEXT_PUBLIC_API_URL=https://shothik.work
NEXT_PUBLIC_SITE_URL=https://www.shothik.ai

# Some modules use a base URL that already includes a path prefix. If unsure,
# set this equal to NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_API_URL_WITH_PREFIX=https://shothik.work

# Tool rewrites / socket prefixes
NEXT_PUBLIC_PARAPHRASE_REDIRECT_PREFIX=paraphrase

# Optional: if set, paraphrase socket connects directly to this URL.
# If unset, the app uses "/${NEXT_PUBLIC_PARAPHRASE_REDIRECT_PREFIX}/socket.io".
NEXT_PUBLIC_PARAPHRASE_SOCKET_URL=

# Optional: required for Sheet features (set to the service prefix used by your API).
NEXT_PUBLIC_SHEET_REDIRECT_PREFIX=

# Optional: used by the presentation tool for socket transport
NEXT_PUBLIC_SOCKET_URL=
NEXT_PUBLIC_SLIDE_REDIRECT_PREFIX=slide
NEXT_PUBLIC_RESEARCH_REDIRECT_PREFIX=research
NEXT_PUBLIC_MARKETING_REDIRECT_PREFIX=/
NEXT_PUBLIC_ANIMATION_SERVICE_URL=
NEXT_PUBLIC_PAYMENT_SYSTEM_URL=

# Convex URL is still used by legacy domains during migration
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=

# InsForge client (target platform for the ongoing migration)
NEXT_PUBLIC_INSFORGE_URL=
NEXT_PUBLIC_INSFORGE_ANON_KEY=

# Social login (if enabled in the UI)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# TestSprite cloud project bootstrap helpers
# Use a live staging or preview URL here. Do not use localhost/127.0.0.1.
TESTSPRITE_PROJECT_URL=
TESTSPRITE_PROJECT_NAME=shothik-web
TESTSPRITE_PROJECT_INSTRUCTION=

# TestSprite runtime secret
# Keep the real value only in ignored local env files such as:
# - .env.local
# - .env.testsprite.local
# - Trae MCP environment configuration
TESTSPRITE_API_KEY=

# Optional authenticated smoke credentials for TestSprite / Playwright
# Leave PLAYWRIGHT_BASE_URL unset for localhost; set it for staging/preview automation.
PLAYWRIGHT_BASE_URL=
PLAYWRIGHT_SMOKE_EMAIL=
PLAYWRIGHT_SMOKE_PASSWORD=
PLAYWRIGHT_VERCEL_PROTECTION_BYPASS=
# Local-only auth artifact. Keep the default under the ignored /.playwright folder.
PLAYWRIGHT_STORAGE_STATE_PATH=.playwright/.auth/smoke-user.json
# When true, Playwright captures auth once and reuses the storage state for later specs.
PLAYWRIGHT_USE_AUTH_SETUP=false
STAGING_APP_URL=https://staging.shothikgpt.com
STAGING_CREATOR_EMAIL=
STAGING_CREATOR_PASSWORD=
STAGING_ADMIN_EMAIL=
STAGING_ADMIN_PASSWORD=
STAGING_READER_EMAIL=
STAGING_READER_PASSWORD=

# Payments (public key only)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
NEXT_PUBLIC_STRIPE_MODE=sandbox
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_placeholder

# Analytics and error tracking
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_SENTRY_DSN=

# Feature flags
NEXT_PUBLIC_WRITING_STUDIO_ENABLED=true
NEXT_PUBLIC_WRITING_STUDIO_API_URL=
NEXT_PUBLIC_ENABLE_PARAPHRASE_SIMPLIFIED=true
NEXT_PUBLIC_EXTRACT_PDF_V2_ENABLED=false
NEXT_PUBLIC_ENABLE_WEBMCP_WIDGET=false
NEXT_PUBLIC_WEBMCP_SCRIPT_URL=

# Optional tool-specific URLs
NEXT_PUBLIC_SHEET_SERVICE_URL=
NEXT_PUBLIC_SLIDE_API_URL=
NEXT_PUBLIC_PARAPHRASE_API_URL=

################################################################################
# Server-only (Node / API routes) – secrets must live here
################################################################################

# Convex (legacy compatibility while migration is incomplete)
CONVEX_DEPLOYMENT=dev:your-deployment-name
CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOY_KEY=
CONVEX_SITE_URL=
CONVEX_JWT_PUBLIC_KEY_N=
JWT_PRIVATE_KEY=

# Clerk (legacy auth in codebase – keep until migration is complete)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_placeholder
CLERK_SECRET_KEY=sk_test_placeholder
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/register

# Preview access policy (server-only). Browser automation smoke users must satisfy
# these checks when preview protection is enabled.
PREVIEW_AUTH_ENABLED=
PREVIEW_ACCESS_ALLOWED_EMAILS=
PREVIEW_ACCESS_ALLOWED_ROLES=
PREVIEW_ACCESS_REQUIRED_SCOPES=

# LLM providers (at least one required by env validation)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2-thinking
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
DEEPSEEK_API_KEY=
AI_INTEGRATIONS_GEMINI_API_KEY=
AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
LETTA_API_KEY=
LETTA_BASE_URL=
LETTA_MODEL=openai/gpt-4o-mini
LETTA_EMBEDDING=openai/text-embedding-3-small

# Stripe (server)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_CREDITS_WEBHOOK_SECRET=
STRIPE_STARS_WEBHOOK_SECRET=
STRIPE_SUBSCRIPTION_WEBHOOK_SECRET=
CREDIT_PURCHASE_SECRET=
STRIPE_PRICE_STUDENT_MONTHLY=
STRIPE_PRICE_STUDENT_YEARLY=
STRIPE_PRICE_RESEARCHER_MONTHLY=
STRIPE_PRICE_RESEARCHER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_CREDITS_100=
STRIPE_PRICE_CREDITS_500=
STRIPE_PRICE_CREDITS_1000=
STRIPE_PRICE_CREDITS_5000=

# Razorpay (server)
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=

# bKash (server)
BKASH_BASE_URL=
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=

# PublishDrive (publishing)
PUBLISHDRIVE_ENABLED=true
NEXT_PUBLIC_PUBLISHDRIVE_ENABLED=true
NEXT_PUBLIC_PUBLISHDRIVE_API_URL=https://api.publishdrive.com/v1
PUBLISHDRIVE_API_KEY=
PUBLISHDRIVE_WEBHOOK_SECRET=

# Google Books / Drive (publishing metadata + manuscript storage)
# Use a referrer-restricted key for public Google Books metadata lookups.
NEXT_PUBLIC_GOOGLE_BOOKS_API_KEY=
# Optional backend alternative if metadata fetches should stay server-side.
GOOGLE_BOOKS_API_KEY=
# Drive access must use OAuth or a service account, not a public API key.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=
GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_DRIVE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Calibre microservice
CALIBRE_SERVICE_URL=http://localhost:3003
NLP_SERVICE_URL=http://localhost:3001
NLP_INFERENCE_URL=http://localhost:3001
AI_DETECTOR_URL=http://localhost:3002
AI_DETECTOR_SERVICE_URL=http://localhost:3002
SHEET_SERVICE_URL=http://localhost:3004
PLAGIARISM_API_URL=https://api-qa.shothik.ai
PLAGIARISM_ENGINE_URL=http://localhost:8000

# Redis / Upstash (used by idempotency and rate limiting helpers)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=
REDIS_TOKEN=

# Security and ops
METRICS_ADMIN_KEY=
IP_ALLOWLIST=
API_KEY_SALT=
GEO_COOKIE_SECRET=
SESSION_SECRET=
GOOGLE_GEOLOCATION_KEY=
RESEND_API_KEY=
SECOND_ME_VAULT_SECRET=
ZOHO_WEBHOOK_SECRET=
ZOHO_WEBHOOK_URL=
ADMIN_EMAILS=
BOOTSTRAP_ADMIN_ENABLED=false
LOG_LEVEL=info

# Optional: MongoDB (only required if features using dbConnect are enabled)
MONGODB_URI=

################################################################################
# Document parsing (LiteParse)
################################################################################

# Enable LiteParse extraction paths (server-side)
LITEPARSE_ENABLED=false
LITEPARSE_MODE=shadow
LITEPARSE_OCR_LANGUAGE=eng
LITEPARSE_OCR_SERVER_URL=
LITEPARSE_DPI=150
LITEPARSE_MAX_PAGES=40
LITEPARSE_NUM_WORKERS=1
LITEPARSE_DISABLE_OCR=false

################################################################################
# InsForge server database / future auth migration
################################################################################

# The chat migration currently uses this server-only InsForge Postgres URL.
DATABASE_URL=

# These are not fully wired in the current codebase yet. Keep them server-only.
BETTER_AUTH_URL=https://shothik.work
NEXT_PUBLIC_BETTER_AUTH_URL=https://shothik.work
BETTER_AUTH_SECRET=
